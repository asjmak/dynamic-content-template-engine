# --- Supabase (diambil dari Project Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service Role key — HANYA dipakai server-side (webhook). JANGAN expose ke client!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret untuk mengautentikasi aplikasi manajemen eksternal yang memanggil /api/webhook
WEBHOOK_SECRET=ganti-dengan-string-acak-yang-kuat

# URL publik situs (untuk Open Graph). Contoh: https://nama.vercel.app
NEXT_PUBLIC_SITE_URL=
